generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── GOVERNANÇA ─────────────────────────────────────────────

model Tenant {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  slug      String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users                  User[]
  userRoles              UserRole[]
  refreshTokens          RefreshToken[]
  auditLogs              AuditLog[]
  systemSettings         SystemSetting[]
  pessoas                Pessoa[]
  pessoaContatos         PessoaContato[]
  pessoaEnderecos        PessoaEndereco[]
  documentos             Documento[]
  notificacoes           Notificacao[]
  reunioes               Reuniao[]
  reuniaoDeliberacoes    ReuniaoDeliberacao[]
  roteiros               RoteiroVisita[]
  roteiroParadas         RoteiroParada[]
  pesquisas              Pesquisa[]
  pesquisaResultados     PesquisaResultado[]
  captacaoDoadores       CaptacaoDoador[]
  materiais              Material[]
  estoques               Estoque[]
  movimentacaoEstoques   MovimentacaoEstoque[]
  contratos              Contrato[]
  contratoAprovacoes     ContratoAprovacao[]
  municipiosEstrategicos MunicipioEstrategico[]
  bairrosEstrategicos    BairroEstrategico[]
  liderancasLocais       LiderancaLocal[]
  vereadoresHistoricos   VereadorHistorico[]
  pessoaPapels           PessoaPapel[]
  tags                   Tag[]
  pessoaTags             PessoaTag[]
  demandas               Demanda[]
  demandaEncaminhamentos DemandaEncaminhamento[]
  demandaAnexos          DemandaAnexo[]
  agendas                Agenda[]
  agendaParticipantes    AgendaParticipante[]
  agendaCheckins         AgendaCheckin[]
  agendaFollowups        AgendaFollowup[]
  centroCustos           CentroCusto[]
  despesas               Despesa[]
  receitas               Receita[]
  tseImportJobs          TseImportJob[]
  tseImportLogs          TseImportLog[]
  gamificacaoRegras      GamificacaoRegra[]
  comunicacaoCampanhas   ComunicacaoCampanha[]
  comunicacaoLogs        ComunicacaoLog[]
  campanhaEstrategias    CampanhaEstrategia[]
  eixoEstrategicos       EixoEstrategico[]
  planoAcaos             PlanoAcao[]
  campanhaParcerias      CampanhaParceria[]
  comunicacaoPautas      ComunicacaoPauta[]
  comunicacaoPecas       ComunicacaoPeca[]
  comunicacaoMencaos     ComunicacaoMencao[]
  campanhas              Campanha[]
  aiProvedors            AiProvedor[]
  aiModelos              AiModelo[]
  aiCopilots             AiCopilot[]
  aiUsoLogs              AiUsoLog[]
  municipios             Municipio[]
  mapaCenarios           MapaCenario[]
  mapaSetors             MapaSetor[]
  tenantSettings         TenantSettings?

  @@map("tenants")
}

enum AppRole {
  admin
  coordenador
  lideranca
  operador
  visualizador
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique
  passwordHash String   @map("password_hash")
  fullName     String   @default("") @map("full_name")
  phone        String?
  cpf          String?
  avatarUrl    String?  @map("avatar_url")
  active       Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  roles              UserRole[]
  refreshTokens      RefreshToken[]
  pessoasCriadas     Pessoa[]       @relation("PessoaCreatedBy")
  demandasCriadas    Demanda[]      @relation("DemandaCreatedBy")
  notificacoes       Notificacao[]
  demandasAtribuidas Demanda[]      @relation("DemandaAtribuidaA")
  eventosCriados     Agenda[]       @relation("AgendaCreatedBy")
  eventosAtribuidos  Agenda[]       @relation("AgendaResponsavelId")
  planosAcao         PlanoAcao[]    @relation("PlanoAcaoResponsavel")
  tenantId           String         @default("00000000-0000-0000-0000-000000000000") @map("tenant_id") @db.Uuid
  tenant             Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  profile            Profile?
  aiUsoLogs          AiUsoLog[]

  @@map("users")
}

model UserRole {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  role      AppRole
  createdAt DateTime @default(now()) @map("created_at")

  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenantId String @default("00000000-0000-0000-0000-000000000000") @map("tenant_id") @db.Uuid
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([userId, role])
  @@map("user_roles")
}

model RefreshToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  tokenHash String   @map("token_hash")
  expiresAt DateTime @map("expires_at")
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenantId String @default("00000000-0000-0000-0000-000000000000") @map("tenant_id") @db.Uuid
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  action    String
  tableName String   @map("table_name")
  recordId  String?  @map("record_id")
  oldData   Json?    @map("old_data")
  newData   Json?    @map("new_data")
  ipAddress String?  @map("ip_address")
  createdAt DateTime @default(now()) @map("created_at")
  tenantId  String   @default("00000000-0000-0000-0000-000000000000") @map("tenant_id") @db.Uuid
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tableName])
  @@index([userId])
  @@index([createdAt(sort: Desc)])
  @@map("audit_logs")
}

model SystemSetting {
  id          String   @id @default(uuid()) @db.Uuid
  key         String
  value       Json     @default("{}")
  description String?
  updatedBy   String?  @map("updated_by") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  tenantId    String   @default("00000000-0000-0000-0000-000000000000") @map("tenant_id") @db.Uuid
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, key])
  @@map("system_settings")
}

// ─── TERRITORIAL ─────────────────────────────────────────────

model Estado {
  id            String   @id @default(uuid()) @db.Uuid
  nome          String
  sigla         String   @unique @db.Char(2)
  geocodigoIbge String?  @unique @map("geocodigo_ibge")
  latitude      Float?
  longitude     Float?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  municipios Municipio[]

  @@map("estados")
}

model Municipio {
  id                       String   @id @default(uuid()) @db.Uuid
  estadoId                 String   @map("estado_id") @db.Uuid
  nome                     String
  geocodigoIbge            String?  @unique @map("geocodigo_ibge")
  populacao                Int?
  populacao2022            Int?     @map("populacao_2022")
  eleitoradoTotal          Int?     @map("eleitorado_total")
  latitude                 Float?
  longitude                Float?
  classificacaoEstrategica String?  @map("classificacao_estrategica")
  prioridadeCampanha       Int?     @map("prioridade_campanha")
  notasEstrategicas        String?  @map("notas_estrategicas")
  tenantId                 String?  @map("tenant_id") @db.Uuid // Optional since it might be global
  createdAt                DateTime @default(now()) @map("created_at")
  updatedAt                DateTime @updatedAt @map("updated_at")

  estado                 Estado                 @relation(fields: [estadoId], references: [id], onDelete: Cascade)
  tenant                 Tenant?                @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  bairros                Bairro[]
  distritos              Distrito[]
  zonas                  ZonaEleitoral[]
  roteiros               RoteiroVisita[]
  enderecos              PessoaEndereco[]
  estoques               Estoque[]
  municipiosEstrategicos MunicipioEstrategico[]
  liderancasLocais       LiderancaLocal[]
  vereadoresHistoricos   VereadorHistorico[]

  @@map("municipios")
}

model Distrito {
  id            String   @id @default(uuid()) @db.Uuid
  municipioId   String   @map("municipio_id") @db.Uuid
  nome          String
  geocodigoIbge String?  @map("geocodigo_ibge")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  municipio Municipio @relation(fields: [municipioId], references: [id], onDelete: Cascade)
  bairros   Bairro[]

  @@map("distritos")
}

model Bairro {
  id                   String   @id @default(uuid()) @db.Uuid
  municipioId          String   @map("municipio_id") @db.Uuid
  distritoId           String?  @map("distrito_id") @db.Uuid
  nome                 String
  classificacao        String? // enum in DB
  zonaTipo             String?  @map("zona_tipo")
  zonaEstrategica      String?  @map("zona_estrategica")
  perfilSocioeconomico String?  @map("perfil_socioeconomico")
  populacaoEstimada    Int?     @map("populacao_estimada")
  latitude             Float?
  longitude            Float?
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  municipio           Municipio           @relation(fields: [municipioId], references: [id], onDelete: Cascade)
  distrito            Distrito?           @relation(fields: [distritoId], references: [id], onDelete: SetNull)
  comunidades         Comunidade[]
  enderecos           PessoaEndereco[]
  bairrosEstrategicos BairroEstrategico[]
  liderancasLocais    LiderancaLocal[]

  @@map("bairros")
}

model Comunidade {
  id        String   @id @default(uuid()) @db.Uuid
  bairroId  String   @map("bairro_id") @db.Uuid
  nome      String
  microarea String?
  latitude  Float?
  longitude Float?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  bairro Bairro @relation(fields: [bairroId], references: [id], onDelete: Cascade)

  @@map("comunidades")
}

model ZonaEleitoral {
  id               String   @id @default(uuid()) @db.Uuid
  municipioId      String   @map("municipio_id") @db.Uuid
  numeroZona       Int      @map("numero_zona")
  tribunalRegional String?  @map("tribunal_regional")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  municipio Municipio        @relation(fields: [municipioId], references: [id], onDelete: Cascade)
  secoes    SecaoEleitoral[]

  @@map("zonas_eleitorais")
}

model SecaoEleitoral {
  id             String   @id @default(uuid()) @db.Uuid
  zonaId         String   @map("zona_id") @db.Uuid
  numeroSecao    Int      @map("numero_secao")
  localVotacao   String?  @map("local_votacao")
  endereco       String?
  eleitoresAptos Int?     @map("eleitores_aptos")
  latitude       Float?
  longitude      Float?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  zona ZonaEleitoral @relation(fields: [zonaId], references: [id], onDelete: Cascade)

  @@map("secoes_eleitorais")
}

// ─── CRM ───────────────────────────────────────────────────

model Pessoa {
  id                  String   @id @default(uuid()) @db.Uuid
  fullName            String   @map("full_name")
  tipoPessoa          String?  @default("pf") @map("tipo_pessoa")
  cpf                 String?
  cnpj                String?
  razaoSocial         String?  @map("razao_social")
  nomeFantasia        String?  @map("nome_fantasia")
  dataNascimento      String?  @map("data_nascimento")
  genero              String?
  escolaridade        String?
  nivelRelacionamento String   @default("desconhecido") @map("nivel_relacionamento")
  observacoes         String?
  score               Int      @default(0)
  isLideranca         Boolean  @default(false) @map("is_lideranca")
  liderancaId         String?  @map("lideranca_id") @db.Uuid
  createdBy           String?  @map("created_by") @db.Uuid
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  creator              User?                @relation("PessoaCreatedBy", fields: [createdBy], references: [id], onDelete: SetNull)
  lideranca            Pessoa?              @relation("PessoaLideranca", fields: [liderancaId], references: [id], onDelete: SetNull)
  votosCaptados        Pessoa[]             @relation("PessoaLideranca")
  demandas             Demanda[]            @relation("DemandaPessoa")
  eventosParticipados  AgendaParticipante[]
  contatos             PessoaContato[]
  enderecos            PessoaEndereco[]
  papeis               PessoaPapel[]
  tags                 PessoaTag[]
  mensagensComunicacao ComunicacaoLog[]
  tenantId             String               @default("00000000-0000-0000-0000-000000000000") @map("tenant_id") @db.Uuid
  tenant               Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  liderancasLocais     LiderancaLocal[]

  @@map("pessoas")
}

model PessoaContato {
  id        String   @id @default(uuid()) @db.Uuid
  pessoaId  String   @map("pessoa_id") @db.Uuid
  tipo      String
  valor     String
  principal Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  pessoa   Pessoa @relation(fields: [pessoaId], references: [id], onDelete: Cascade)
  tenantId String @default("00000000-0000-0000-0000-000000000000") @map("tenant_id") @db.Uuid
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("pessoas_contatos")
}

model PessoaEndereco {
  id          String   @id @default(uuid()) @db.Uuid
  pessoaId    String   @map("pessoa_id") @db.Uuid
  tipo        String?
  logradouro  String?
  numero      String?
  complemento String?
  cep         String?
  bairroId    String?  @map("bairro_id") @db.Uuid
  municipioId String?  @map("municipio_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")

  pessoa    Pessoa     @relation(fields: [pessoaId], references: [id], onDelete: Cascade)
  bairro    Bairro?    @relation(fields: [bairroId], references: [id], onDelete: SetNull)
  municipio Municipio? @relation(fields: [municipioId], references: [id], onDelete: SetNull)

  tenantId String @default("00000000-0000-0000-0000-000000000000") @map("tenant_id") @db.Uuid
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("pessoas_enderecos")
}

model PessoaPapel {
  id        String   @id @default(uuid()) @db.Uuid
  pessoaId  String   @map("pessoa_id") @db.Uuid
  papel     String
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")

  pessoa   Pessoa @relation(fields: [pessoaId], references: [id], onDelete: Cascade)
  tenantId String @default("00000000-0000-0000-0000-000000000000") @map("tenant_id") @db.Uuid
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("pessoas_papeis")
}

model Tag {
  id        String   @id @default(uuid()) @db.Uuid
  nome      String   @unique
  cor       String?
  categoria String?
  createdAt DateTime @default(now()) @map("created_at")

  pessoas  PessoaTag[]
  tenantId String      @default("00000000-0000-0000-0000-000000000000") @map("tenant_id") @db.Uuid
  tenant   Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tags")
}

model PessoaTag {
  pessoaId  String   @map("pessoa_id") @db.Uuid
  tagId     String   @map("tag_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  pessoa   Pessoa @relation(fields: [pessoaId], references: [id], onDelete: Cascade)
  tag      Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)
  tenantId String @default("00000000-0000-0000-0000-000000000000") @map("tenant_id") @db.Uuid
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@id([pessoaId, tagId])
  @@map("pessoas_tags")
}

// ─── DEMANDAS ──────────────────────────────────────────────

model Demanda {
  id                 String    @id @default(uuid()) @db.Uuid
  pessoaId           String?   @map("pessoa_id") @db.Uuid
  titulo             String
  descricao          String?
  status             String    @default("aberta")
  categoria          String?
  prioridade         String    @default("media")
  origem             String?
  protocolo          String?
  satisfacaoCidadao  Float?    @map("satisfacao_cidadao")
  resolucaoDescricao String?   @map("resolucao_descricao")
  municipioId        String?   @map("municipio_id") @db.Uuid
  bairroId           String?   @map("bairro_id") @db.Uuid
  eixoId             String?   @map("eixo_id") @db.Uuid
  createdBy          String?   @map("created_by") @db.Uuid
  atribuidoA         String?   @map("atribuido_a") @db.Uuid
  dataAbertura       DateTime  @default(now()) @map("data_abertura")
  dataPrazo          DateTime? @map("data_prazo")
  dataResolucao      DateTime? @map("data_resolucao")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  pessoa          Pessoa?                 @relation("DemandaPessoa", fields: [pessoaId], references: [id], onDelete: SetNull)
  creator         User?                   @relation("DemandaCreatedBy", fields: [createdBy], references: [id], onDelete: SetNull)
  atribuido       User?                   @relation("DemandaAtribuidaA", fields: [atribuidoA], references: [id], onDelete: SetNull)
  encaminhamentos DemandaEncaminhamento[]
  anexos          DemandaAnexo[]
  eixoEstrategico EixoEstrategico?        @relation("DemandaEixo", fields: [eixoId], references: [id], onDelete: SetNull)
  tenantId        String                  @default("00000000-0000-0000-0000-000000000000") @map("tenant_id") @db.Uuid
  tenant          Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("demandas")
}

model DemandaEncaminhamento {
  id            String   @id @default(uuid()) @db.Uuid
  demandaId     String   @map("demanda_id") @db.Uuid
  deUsuarioId   String?  @map("de_usuario_id") @db.Uuid
  paraUsuarioId String?  @map("para_usuario_id") @db.Uuid
  observacao    String?
  createdAt     DateTime @default(now()) @map("created_at")

  demanda  Demanda @relation(fields: [demandaId], references: [id], onDelete: Cascade)
  tenantId String  @default("00000000-0000-0000-0000-000000000000") @map("tenant_id") @db.Uuid
  tenant   Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("demandas_encaminhamentos")
}

model DemandaAnexo {
  id         String   @id @default(uuid()) @db.Uuid
  demandaId  String   @map("demanda_id") @db.Uuid
  arquivoUrl String   @map("arquivo_url")
  descricao  String?
  tipo       String?
  createdAt  DateTime @default(now()) @map("created_at")

  demanda  Demanda @relation(fields: [demandaId], references: [id], onDelete: Cascade)
  tenantId String  @default("00000000-0000-0000-0000-000000000000") @map("tenant_id") @db.Uuid
  tenant   Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("demandas_anexos")
}

// ─── AGENDA ────────────────────────────────────────────────

model Agenda {
  id            String    @id @default(uuid()) @db.Uuid
  titulo        String
  descricao     String?
  tipo          String
  dataInicio    DateTime  @map("data_inicio")
  dataFim       DateTime? @map("data_fim")
  diaInteiro    Boolean   @default(false) @map("dia_inteiro")
  local         String?
  municipioId   String?   @map("municipio_id") @db.Uuid
  bairroId      String?   @map("bairro_id") @db.Uuid
  latitude      Float?
  longitude     Float?
  status        String    @default("agendado")
  planoAcaoId   String?   @map("plano_acao_id") @db.Uuid
  responsavelId String?   @map("responsavel_id") @db.Uuid
  createdBy     String?   @map("created_by") @db.Uuid
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  creator       User?                @relation("AgendaCreatedBy", fields: [createdBy], references: [id], onDelete: SetNull)
  responsavel   User?                @relation("AgendaResponsavelId", fields: [responsavelId], references: [id], onDelete: SetNull)
  participantes AgendaParticipante[]
  checkins      AgendaCheckin[]
  followups     AgendaFollowup[]
  planoAcao     PlanoAcao?           @relation("AgendaPlanoAcao", fields: [planoAcaoId], references: [id], onDelete: SetNull)
  tenantId      String               @default("00000000-0000-0000-0000-000000000000") @map("tenant_id") @db.Uuid
  tenant        Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("agenda")
}

model AgendaParticipante {
  id         String   @id @default(uuid()) @db.Uuid
  agendaId   String   @map("agenda_id") @db.Uuid
  pessoaId   String   @map("pessoa_id") @db.Uuid
  papel      String?
  confirmado Boolean  @default(false)
  compareceu Boolean  @default(false)
  createdAt  DateTime @default(now()) @map("created_at")

  agenda   Agenda @relation(fields: [agendaId], references: [id], onDelete: Cascade)
  pessoa   Pessoa @relation(fields: [pessoaId], references: [id], onDelete: Cascade)
  tenantId String @default("00000000-0000-0000-0000-000000000000") @map("tenant_id") @db.Uuid
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("agenda_participantes")
}

model AgendaCheckin {
  id        String   @id @default(uuid()) @db.Uuid
  agendaId  String   @map("agenda_id") @db.Uuid
  usuarioId String?  @map("usuario_id") @db.Uuid
  tipo      String
  latitude  Float?
  longitude Float?
  createdAt DateTime @default(now()) @map("created_at")

  agenda   Agenda @relation(fields: [agendaId], references: [id], onDelete: Cascade)
  tenantId String @default("00000000-0000-0000-0000-000000000000") @map("tenant_id") @db.Uuid
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("agenda_checkins")
}

model AgendaFollowup {
  id            String    @id @default(uuid()) @db.Uuid
  agendaId      String    @map("agenda_id") @db.Uuid
  descricao     String
  responsavelId String?   @map("responsavel_id") @db.Uuid
  prazo         DateTime?
  concluido     Boolean   @default(false)
  createdAt     DateTime  @default(now()) @map("created_at")

  agenda   Agenda @relation(fields: [agendaId], references: [id], onDelete: Cascade)
  tenantId String @default("00000000-0000-0000-0000-000000000000") @map("tenant_id") @db.Uuid
