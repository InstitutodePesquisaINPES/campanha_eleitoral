  @@index([pessoaId])
  @@index([campanhaId])
  @@map("comunicacao_logs")
}

// ─── WAR ROOM (PLANEJAMENTO ESTRATÉGICO) ─────────────────

model CampanhaEstrategia {
  id               String    @id @default(uuid()) @db.Uuid
  nome             String
  cargo            String // prefeito, vereador, deputado
  ano              Int
  metaVotos        Int?      @map("meta_votos")
  orcamentoGlobal  Float?    @map("orcamento_global")
  dataEleicao      DateTime? @map("data_eleicao")
  status           String    @default("planejamento") // planejamento, ativa, concluida
  abrangencia      String    @default("municipal") // nacional, estadual, municipal, zonal
  estadoId         String?   @map("estado_id") @db.Uuid
  municipioId      String?   @map("municipio_id") @db.Uuid
  parentCampanhaId String?   @map("parent_campanha_id") @db.Uuid
  createdBy        String?   @map("created_by") @db.Uuid
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  parentCampanha CampanhaEstrategia?  @relation("SubCampanhas", fields: [parentCampanhaId], references: [id], onDelete: SetNull)
  subCampanhas   CampanhaEstrategia[] @relation("SubCampanhas")
  parcerias      CampanhaParceria[]
  eixos          EixoEstrategico[]
  tenantId       String               @default("00000000-0000-0000-0000-000000000000") @map("tenant_id") @db.Uuid
  tenant         Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("campanhas_estrategias")
}

model EixoEstrategico {
  id               String   @id @default(uuid()) @db.Uuid
  campanhaId       String   @map("campanha_id") @db.Uuid
  nome             String // Saude, Educacao, Infraestrutura
  descricao        String?
  cor              String?
  orcamentoAlocado Float?   @map("orcamento_alocado")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  campanha           CampanhaEstrategia @relation(fields: [campanhaId], references: [id], onDelete: Cascade)
  planosAcao         PlanoAcao[]
  demandasVinculadas Demanda[]          @relation("DemandaEixo")
  tenantId           String             @default("00000000-0000-0000-0000-000000000000") @map("tenant_id") @db.Uuid
  tenant             Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("eixos_estrategicos")
}

model PlanoAcao {
  id                String    @id @default(uuid()) @db.Uuid
  eixoId            String    @map("eixo_id") @db.Uuid
  titulo            String
  descricao         String?
  status            String    @default("todo") // todo, doing, done, blocked
  dataInicio        DateTime? @map("data_inicio")
  dataFim           DateTime? @map("data_fim")
  dataConclusao     DateTime? @map("data_conclusao")
  orcamentoPrevisto Float?    @map("orcamento_previsto")
  responsavelId     String?   @map("responsavel_id") @db.Uuid
  dependeDeId       String?   @map("depende_de_id") @db.Uuid
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  eixo               EixoEstrategico @relation(fields: [eixoId], references: [id], onDelete: Cascade)
  responsavel        User?           @relation("PlanoAcaoResponsavel", fields: [responsavelId], references: [id], onDelete: SetNull)
  dependeDe          PlanoAcao?      @relation("DependenciaAcao", fields: [dependeDeId], references: [id], onDelete: SetNull)
  dependentes        PlanoAcao[]     @relation("DependenciaAcao")
  agendasVinculadas  Agenda[]        @relation("AgendaPlanoAcao")
  despesasVinculadas Despesa[]       @relation("DespesaPlanoAcao")
  tenantId           String          @default("00000000-0000-0000-0000-000000000000") @map("tenant_id") @db.Uuid
  tenant             Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("planos_acao")
}

model CampanhaParceria {
  id                    String   @id @default(uuid()) @db.Uuid
  campanhaId            String   @map("campanha_id") @db.Uuid
  candidatoParceiroNome String   @map("candidato_parceiro_nome")
  cargoParceiro         String   @map("cargo_parceiro")
  municipioId           String?  @map("municipio_id") @db.Uuid
  pesoEstrategico       Int      @default(3) @map("peso_estrategico") // 1 a 5 estrelas
  observacoes           String?
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  campanha CampanhaEstrategia @relation(fields: [campanhaId], references: [id], onDelete: Cascade)
  tenantId String             @default("00000000-0000-0000-0000-000000000000") @map("tenant_id") @db.Uuid
  tenant   Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("campanhas_parcerias")
}

