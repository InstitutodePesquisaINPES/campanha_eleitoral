// ─── OMNICHANNEL E COMUNICACAO ─────────────────────────────

model ComunicacaoCampanha {
  id        String   @id @default(uuid()) @db.Uuid
  nome      String
  tipo      String   @default("whatsapp") // whatsapp, sms, email
  status    String   @default("draft") // draft, processing, completed, failed
  filtros   Json? // os filtros usados na segmentacao para esse envio
  mensagem  String // template da mensagem
  createdBy String?  @map("created_by") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  logs     ComunicacaoLog[]
  tenantId String           @default("00000000-0000-0000-0000-000000000000") @map("tenant_id") @db.Uuid
  tenant   Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("comunicacao_campanhas")
